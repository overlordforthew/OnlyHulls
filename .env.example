# Core app and infra
DATABASE_URL=postgresql://onlyhulls:changeme@localhost:5433/onlyhulls
REDIS_URL=redis://localhost:6380
MEILISEARCH_URL=http://localhost:7701
MEILISEARCH_API_KEY=replace_me_meili_master_key
AUTH_SECRET=<run: openssl rand -base64 32>
NEXT_PUBLIC_APP_URL=https://onlyhulls.com
NEXTAUTH_URL=https://onlyhulls.com
NODE_ENV=production

# Billing (required only for paid plans)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# The app uses server-side checkout today, so this is optional unless
# you later add client-side Stripe components.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_BUYER_PLUS=price_...
STRIPE_PRICE_SELLER_STANDARD=price_...
STRIPE_PRICE_SELLER_FEATURED=price_...
STRIPE_PRICE_BROKER=price_...

# Email (required for verification, password reset, seller notifications)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=OnlyHulls <hello@onlyhulls.com>

# Media storage (required for uploads)
# Choose one:
# 1. local disk
MEDIA_BACKEND=local
LOCAL_MEDIA_ROOT=/media-data
# 2. or S3-compatible object storage
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=onlyhulls-media
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...

# AI matching (required for embeddings and real semantic matching)
OPENAI_API_KEY=sk-...

# Optional model-backed match reranking / explanations
# Recommended first live setup: OpenRouter using the existing MasterCommander-style key
AI_PROVIDER=openrouter
OPENROUTER_KEY=sk-or-v1-...
OPENROUTER_CHAT_MODEL=google/gemma-3-27b-it:free

# Optional local AI generation
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_MS=30000

# Optional analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# Optional advanced buyer chat profiling
# Set this only if you are running scripts/claude-proxy.mjs on the host.
CLAUDE_PROXY_URL=http://host.docker.internal:3099
