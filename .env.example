# Core app and infra
DATABASE_URL=postgresql://onlyhulls:changeme@localhost:5433/onlyhulls
REDIS_URL=redis://localhost:6380
MEILISEARCH_URL=http://localhost:7701
MEILISEARCH_API_KEY=replace_me_meili_master_key
AUTH_SECRET=<run: openssl rand -base64 32>
NEXT_PUBLIC_APP_URL=https://onlyhulls.com
NEXTAUTH_URL=https://onlyhulls.com
NODE_ENV=production

# Billing (required only for paid plans)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# The app uses server-side checkout today, so this is optional unless
# you later add client-side Stripe components.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_BUYER_PLUS=price_...
STRIPE_PRICE_SELLER_STANDARD=price_...
STRIPE_PRICE_SELLER_FEATURED=price_...
STRIPE_PRICE_BROKER=price_...

# Email (required for verification, password reset, seller notifications)
# Choose one:
# 1. SMTP relay
SMTP_HOST=10.0.1.1
SMTP_PORT=25
SMTP_SECURE=false
SMTP_FROM=OnlyHulls <overlord.gil.ai@gmail.com>
# Optional if your relay requires auth:
SMTP_USER=
SMTP_PASS=
# Optional owner alerts destination(s); comma-separate multiple inboxes.
OWNER_ALERT_EMAILS=gilbarden@gmail.com
# 2. or Resend API
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=OnlyHulls <hello@onlyhulls.com>

# Media storage (required for uploads)
# Choose one:
# 1. local disk
MEDIA_BACKEND=local
LOCAL_MEDIA_ROOT=/media-data
# 2. or S3-compatible object storage
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=onlyhulls-media
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...

# Location search and future map UI
# Keep PUBLIC_MAP_ENABLED=false until geocode coverage and tile licensing are ready.
PUBLIC_MAP_ENABLED=false
NEXT_PUBLIC_MAP_ENABLED=false
MAPTILER_KEY=
# Recommended production backfill provider: opencage. Public Nominatim is validation-only.
LOCATION_GEOCODING_PROVIDER=disabled
# Required for Nominatim and useful as provider contact metadata.
LOCATION_GEOCODING_USER_AGENT=OnlyHulls/1.0 (admin@onlyhulls.com)
LOCATION_GEOCODING_EMAIL=
# Required when LOCATION_GEOCODING_PROVIDER=opencage.
LOCATION_GEOCODING_API_KEY=
# Optional: defaults to provider-safe values, 1100ms/8000ms for Nominatim and 200ms/8000ms for OpenCage.
LOCATION_GEOCODING_DELAY_MS=
LOCATION_GEOCODING_TIMEOUT_MS=
# Recommended first commercial tile provider: MapTiler Flex. Restrict the key by HTTP referrer.
NEXT_PUBLIC_MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=$MAPTILER_KEY
NEXT_PUBLIC_MAP_ATTRIBUTION=© MapTiler © OpenStreetMap contributors
NEXT_PUBLIC_MAP_RESOURCE_ORIGINS=https://api.maptiler.com,https://tiles.maptiler.com
# Used by launch preflight to verify referrer-restricted map keys the same way a browser does.
MAP_STYLE_PING_REFERER=https://onlyhulls.com/boats
MAP_STYLE_PING_ALLOWED_HOSTS=
# Admin launch gate thresholds for /admin/map-readiness.
MAP_READINESS_MIN_MARKET_TAG_PCT=95
MAP_READINESS_MIN_CITY_OR_BETTER_PCT=85
MAP_READINESS_MIN_PUBLIC_PIN_PCT=85
MAP_READINESS_MIN_NON_APPROX_PUBLIC_PIN_PCT=50
MAP_READINESS_MAX_REVIEW_FAILED_PCT=0
MAP_READINESS_STALE_PIN_DAYS=90
MAP_READINESS_MIN_PIN_SCORE=0.6

# AI matching (required for embeddings and real semantic matching)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional model-backed match reranking / explanations
# Recommended first live setup: OpenRouter using a reliable paid model plus
# OpenRouter-backed OpenAI embeddings to preserve the existing 1536-dim schema.
AI_PROVIDER=openrouter
OPENROUTER_KEY=sk-or-v1-...
OPENROUTER_CHAT_MODEL=openai/gpt-4.1-mini,openrouter/free
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional local AI generation
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_MS=30000

# Optional analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# Optional advanced buyer chat profiling
# Set this only if you are running scripts/claude-proxy.mjs on the host.
CLAUDE_PROXY_URL=http://host.docker.internal:3099
